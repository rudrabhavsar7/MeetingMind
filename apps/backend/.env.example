MEETINGMIND_ENV=development
MEETINGMIND_DEBUG=true
MEETINGMIND_API_V1_PREFIX=/api/v1
MEETINGMIND_CORS_ORIGINS=http://localhost:3000,chrome-extension://*
MEETINGMIND_DATABASE_URL=postgresql+asyncpg://meetingmind:meetingmind@localhost:5432/meetingmind
# Team development/staging override this secret locally with the Supabase PostgreSQL URL.
# The Supabase database role fixes the environment search_path; never commit credentials.
MEETINGMIND_REDIS_URL=redis://localhost:6379/0
MEETINGMIND_STORAGE_ENDPOINT=http://localhost:9000
MEETINGMIND_STORAGE_BUCKET=meetingmind
# Generate this value locally with: poetry run python -m scripts.rotate_local_jwt_secret
MEETINGMIND_JWT_SECRET=change-me-in-local-env
MEETINGMIND_FRONTEND_URL=http://localhost:3000
# Keep disabled unless an operator-approved local SMTP sink/provider is configured.
MEETINGMIND_PASSWORD_RESET_NOTIFIER=disabled
MEETINGMIND_SMTP_HOST=localhost
MEETINGMIND_SMTP_PORT=1025
MEETINGMIND_SMTP_STARTTLS=false
MEETINGMIND_SMTP_USERNAME=
MEETINGMIND_SMTP_PASSWORD=
MEETINGMIND_SMTP_FROM_EMAIL=meetingmind@localhost
MEETINGMIND_SMTP_TIMEOUT_SECONDS=10
